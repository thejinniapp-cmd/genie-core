# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_ANON_KEY=your-anon-key

# ── OpenRouter (modelo unificado) ─────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Anthropic (directo, opcional si usas OpenRouter) ─────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key

# ── Canales ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-token
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ── API ───────────────────────────────────────────────────────────────────────
API_SECRET_KEY=your-secret-key-min-32-chars
API_PORT=8000
ENVIRONMENT=development

# ── Railway (infraestructura de workers) ──────────────────────────────────────
RAILWAY_API_TOKEN=your-railway-token
RAILWAY_PROJECT_ID=your-railway-project-id

# ── Genie ─────────────────────────────────────────────────────────────────────
GENIE_DEFAULT_MODEL=anthropic/claude-sonnet-4-5
GENIE_FAST_MODEL=anthropic/claude-haiku-4-5
GENIE_MAX_TOKENS=4096
POLL_INTERVAL_SECONDS=10
